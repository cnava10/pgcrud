<!doctype html>
<html lang="en">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>PostgreSQL CRUD Application</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>
  <div class="container mt-4">
    <h1>PostgreSQL CRUD Application</h1>

    <% if (message !=="success" ) { %>
      <h2>Error</h2>
      <p>
        <%= message %>
      </p>
      <% } else { %>
        <h3>Employee List</h3>
        <a href="/add" class="btn btn-primary mb-3">Add Employee</a>

        <table class="table table-bordered">
          <thead>
            <tr>
              <th>ID</th>
              <th>Name</th>
              <th>Email</th>
              <th>Salary</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% model.forEach(employee=> { %>
              <tr>
                <td>
                  <%= employee.emp_id %>
                </td>
                <td>
                  <%= employee.emp_name %>
                </td>
                <td>
                  <%= employee.emp_email %>
                </td>
                <td>
                  <%= employee.emp_salary %>
                </td>
                <td>
                  <a href="/edit/<%= employee.emp_id %>" class="btn btn-warning btn-sm">Edit</a>
                  <a href="/delete/<%= employee.emp_id %>" class="btn btn-danger btn-sm">Delete</a>
                </td>
              </tr>
              <% }) %>
          </tbody>
        </table>
        <% } %>
  </div>
</body>

</html>